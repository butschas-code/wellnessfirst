---
import Container from '@/components/layout/Container.astro';
import ProductCard from '@/components/cards/ProductCard.astro';
import { formatDate, formatTime } from '@/lib/format';
import { offerPath } from '@/lib/offer-paths';
import type { ProductEntry, WebinarEntry, ConsultationEntry } from '@/types/content';

interface Props {
  products: ProductEntry[];
  webinar?: WebinarEntry;
  consultation?: ConsultationEntry;
}

const { products, webinar, consultation } = Astro.props;
const hasRow = products.length > 0 || webinar != null || consultation != null;
---

{
  hasRow && (
    <section class="border-t-2 border-ink bg-paper py-12 md:py-16" aria-label="Related offers">
      <Container>
        <h2 class="text-eyebrow">From this article</h2>
        <p class="mt-2 max-w-2xl font-display text-2xl text-ink md:text-3xl">
          Ways to go deeper
        </p>
        <p class="mt-2 max-w-2xl text-charcoal leading-relaxed">Next steps, if you want them—none required.</p>
        {products.length > 0 && (
          <div class="mt-10">
            <h3 class="text-sm font-medium uppercase tracking-[0.12em] text-ink-500">Selected products</h3>
            <ul
              class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3"
              role="list"
            >
              {products.map((p) => (
                <li>
                  <ProductCard entry={p} />
                </li>
              ))}
            </ul>
          </div>
        )}
        {(webinar != null || consultation != null) && (
          <div class="mt-10 grid gap-6 lg:grid-cols-2">
            {webinar && (
              <div class="flex flex-col border-0 border-t-2 border-ink bg-white pt-6 sm:pt-7">
                <p class="text-eyebrow text-[0.7rem]">Webinar</p>
                <h3 class="mt-1 font-display text-xl text-ink sm:text-2xl">
                  <a
                    class="text-ink transition-colors hover:text-secondary"
                    href={offerPath('webinars', webinar)}
                  >
                    {webinar.data.title}
                  </a>
                </h3>
                <p class="mt-2 text-charcoal leading-relaxed">{webinar.data.excerpt}</p>
                <p class="mt-3 text-sm text-ink-500">
                  {formatDate(webinar.data.startAt)} at {formatTime(webinar.data.startAt)} · {webinar.data.host}
                </p>
                <a class="btn-secondary mt-4 w-fit" href={offerPath('webinars', webinar)}>
                  Session details
                </a>
              </div>
            )}
            {consultation && (
              <div class="flex flex-col border-0 border-t-2 border-ink bg-white pt-6 sm:pt-7">
                <p class="text-eyebrow text-[0.7rem]">Consultation</p>
                <h3 class="mt-1 font-display text-xl text-ink sm:text-2xl">
                  <a
                    class="text-ink transition-colors hover:text-secondary"
                    href={offerPath('consultations', consultation)}
                  >
                    {consultation.data.title}
                  </a>
                </h3>
                <p class="mt-2 text-charcoal leading-relaxed">{consultation.data.summary}</p>
                <a class="btn-secondary mt-4 w-fit" href={offerPath('consultations', consultation)}>
                  View offering
                </a>
              </div>
            )}
          </div>
        )}
      </Container>
    </section>
  )
}
