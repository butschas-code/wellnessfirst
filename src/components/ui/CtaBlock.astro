---
export type CtaVariant = 'primary' | 'secondary' | 'ghost';

interface Props {
  title: string;
  body: string;
  href: string;
  label: string;
  variant?: CtaVariant;
  id?: string;
  align?: 'left' | 'center';
  /** Optional second action—same visual weight as ghost by default. */
  secondaryHref?: string;
  secondaryLabel?: string;
}

const { title, body, href, label, variant = 'primary', id, align = 'left', secondaryHref, secondaryLabel } = Astro.props;
const linkClass = variant === 'primary' ? 'btn-primary' : variant === 'secondary' ? 'btn-secondary' : 'btn-ghost';
---

<aside
  id={id}
  class="border-0 border-t-2 border-ink bg-transparent pt-8 md:pt-10"
  aria-labelledby={id ? `${id}-title` : undefined}
>
  <div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
    <h2 id={id ? `${id}-title` : undefined} class="font-display text-2xl text-ink md:text-3xl">
      {title}
    </h2>
    <p class="mt-3 leading-relaxed text-charcoal">{body}</p>
    <div
      class:list={[
        'mt-6 flex flex-col gap-3 sm:flex-row sm:items-center',
        align === 'center' && 'sm:justify-center',
      ]}
    >
      <a href={href} class:list={['inline-flex w-fit', linkClass]}>
        {label}
      </a>
      {secondaryHref && secondaryLabel && (
        <a href={secondaryHref} class="btn-ghost inline-flex w-fit sm:ml-0">
          {secondaryLabel}
        </a>
      )}
    </div>
  </div>
</aside>
