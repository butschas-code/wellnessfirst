---
import { LOGIN_PATH, SIGNUP_PATH } from '@/lib/auth/constants';

interface Props {
  /** UX tier rendered inside the gate card. */
  variant: 'member_soft_gate' | 'paid_locked' | 'webinar_locked';
  /** Used for login/signup `next=` preservation. */
  nextPath: string;
  /** Optional line shown under the headline (e.g. excerpt). */
  lead?: string;
}

const { variant, nextPath, lead } = Astro.props;
const q = encodeURIComponent(nextPath.startsWith('/') ? nextPath : `/${nextPath}`);
---

<div class="rounded-2xl border border-ink/12 bg-paper/95 px-6 py-8 shadow-elevated sm:px-8">
  {
    variant === 'member_soft_gate' && (
      <>
        <p class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-secondary">Member library</p>
        <h2 class="mt-3 font-display text-2xl tracking-tight text-ink">Continue reading with a free account</h2>
        {lead && <p class="mt-4 max-w-prose text-pretty text-base leading-relaxed text-ink-600">{lead}</p>}
        <p class="mt-4 max-w-prose text-pretty text-sm leading-relaxed text-ink-600">
          Create a free Wellness Space account to open member articles and downloads—still private to you, still without comments or feeds.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a class="btn-primary inline-flex justify-center no-underline" href={`${SIGNUP_PATH}?next=${q}`}>
            Create free account
          </a>
          <a class="btn-secondary inline-flex justify-center no-underline" href={`${LOGIN_PATH}?next=${q}`}>Log in</a>
        </div>
      </>
    )
  }
  {
    variant === 'paid_locked' && (
      <>
        <p class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-secondary">Coming soon</p>
        <h2 class="mt-3 font-display text-2xl tracking-tight text-ink">Guided program access</h2>
        {lead && <p class="mt-4 max-w-prose text-pretty text-base leading-relaxed text-ink-600">{lead}</p>}
        <p class="mt-4 max-w-prose text-pretty text-sm leading-relaxed text-ink-600">
          This resource is part of a future guided program. We will open enrolment calmly—no urgency tricks—when the pathway is ready.
        </p>
      </>
    )
  }
  {
    variant === 'webinar_locked' && (
      <>
        <p class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-secondary">Webinar library</p>
        <h2 class="mt-3 font-display text-2xl tracking-tight text-ink">For participants after the session</h2>
        {lead && <p class="mt-4 max-w-prose text-pretty text-base leading-relaxed text-ink-600">{lead}</p>}
        <p class="mt-4 max-w-prose text-pretty text-sm leading-relaxed text-ink-600">
          Available to participants after booking or attending the related webinar. If you believe you should already see this, log in with the email you used to register.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a class="btn-primary inline-flex justify-center no-underline" href={`${LOGIN_PATH}?next=${q}`}>Log in</a>
          <a class="btn-secondary inline-flex justify-center no-underline" href={`${SIGNUP_PATH}?next=${q}`}>
            Create free account
          </a>
        </div>
      </>
    )
  }
</div>
