---
import '@/styles/global.css';
import { site, socialPreview } from '@/lib/site';
import SiteHeader from '@/components/site/SiteHeader.astro';
import SiteFooter from '@/components/site/SiteFooter.astro';
import { resolveOgImage, siteGraphJsonLd } from '@/lib/seo';
import { WFG_HOME_SCROLL_FIRST_BG } from '@/lib/home-scroll-colors';

interface Props {
  title: string;
  description?: string;
  ogImagePath?: string;
  /** Important for social previews and accessibility when the image carries meaning. */
  ogImageAlt?: string;
  canonicalPath?: string;
  mainClass?: string;
  /** e.g. homepage scroll tint: `wfg-home-body` */
  bodyClass?: string;
  noIndex?: boolean;
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  /** Extra JSON-LD for the page (Article, Product, Event, etc.) — merged in a separate script. */
  jsonLd?: Record<string, unknown>;
  /** Skip default Organization + WebSite graph (almost never needed). */
  omitSiteJsonLd?: boolean;
}

const {
  title,
  description,
  ogImagePath,
  ogImageAlt,
  canonicalPath,
  mainClass,
  bodyClass,
  noIndex,
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
  jsonLd,
  omitSiteJsonLd = false,
} = Astro.props;

const resolvedDescription = description ?? site.description;
const pageTitle = title === site.name ? title : `${title} · ${site.name}`;
const siteBase = Astro.site ?? new URL('http://localhost:4321');
const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, siteBase);
const { url: ogImageUrl, isDefault } = resolveOgImage(ogImagePath);
const resolvedOgAlt =
  ogImageAlt ?? (isDefault ? `${site.name} — share preview` : `Image for: ${title}`);
const defaultOg = socialPreview.defaultOgImage;
const isSvgDefault = !ogImagePath || ogImagePath === defaultOg || ogImagePath?.endsWith('.svg');
/** Same home ambient + GSAP `scrollColorTransition` as `index.astro` for every public page. */
const homeFirstPaintStyle = `background-color: ${WFG_HOME_SCROLL_FIRST_BG}; background-image: none;`;
---

<!doctype html>
<html lang="en-GB" class="scroll-smooth" style={homeFirstPaintStyle}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a2334" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={resolvedDescription} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    {!noIndex && <meta name="robots" content="index, follow" />}
    <link rel="canonical" href={canonicalUrl.toString()} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={resolvedOgAlt} />
    {!isSvgDefault && (
      <>
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    )}
    {ogType === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === 'article' && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === 'article' && articleAuthor && <meta property="article:author" content={articleAuthor} />}
    {ogType === 'article' && articleSection && <meta property="article:section" content={articleSection} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={resolvedOgAlt} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&display=swap"
      rel="stylesheet"
    />
    {!omitSiteJsonLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(siteGraphJsonLd())} />
    )}
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <slot name="head" />
  </head>
  <body
    class:list={['flex', 'min-h-screen', 'flex-col', 'wfg-home-body', bodyClass]}
    data-contact-email={site.contactEmail}
    style={homeFirstPaintStyle}
  >
    <a
      href="#main-content"
      class="fixed left-3 top-3 z-[100] -translate-y-24 rounded-lg bg-ink px-3 py-2 text-sm text-white opacity-0 transition-transform focus:translate-y-0 focus:opacity-100 focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-ink"
    >
      Skip to main content
    </a>
    <SiteHeader />
    <main
      id="main-content"
      class:list={['flex-1', 'pt-20 sm:pt-24', mainClass]}
      tabindex="-1"
    >
      <slot />
    </main>
    <slot name="prefooter" />
    <slot name="footer">
      <SiteFooter />
    </slot>
    <script>
      import { initWfgForms } from '@/scripts/wfg-forms';
      import { initWfgMotion } from '@/scripts/wfg-motion';
      import { scrollColorTransition } from '@/scripts/scroll-color-transition';
      const boot = () => {
        initWfgForms();
        initWfgMotion();
        scrollColorTransition();
      };
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', boot);
      } else {
        boot();
      }
    </script>
  </body>
</html>
