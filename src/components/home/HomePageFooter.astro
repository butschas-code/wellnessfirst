---
import { site } from '@/lib/site';
import { homeFooterNav, homeFooterLegal, homeFooterTagline } from '@/lib/homepage-marketing';

const year = new Date().getUTCFullYear();
const mail = site.contactEmail;
---

<footer class="mt-auto border-t border-primary/10 bg-white/95">
  <div class="container-wfg max-w-4xl py-12 md:py-16">
    <p class="max-w-2xl text-sm leading-relaxed text-charcoal sm:text-base">
      {homeFooterTagline}
    </p>
    <a class="link-wfg-ghost mt-4 inline-block text-sm" href={`mailto:${mail}`}>
      {mail}
    </a>
    <nav class="mt-8" aria-label="Footer">
      <ul class="flex flex-wrap gap-x-6 gap-y-2" role="list">
        {homeFooterNav.map((item) => (
          <li>
            <a
              class="text-sm text-ink underline decoration-ink/20 decoration-1 underline-offset-4 transition-colors hover:text-secondary"
              href={item.href}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <ul class="mt-6 flex flex-wrap gap-x-5 gap-y-1 text-sm text-ink-500" role="list">
      {homeFooterLegal.map((item) => (
        <li>
          <a class="link-wfg-ghost" href={item.href}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <p class="mt-8 text-sm text-ink-500">© {year} {site.name}</p>
  </div>
</footer>
