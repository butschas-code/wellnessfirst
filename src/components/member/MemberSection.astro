---
interface Props {
  eyebrow?: string;
  title: string;
  /** Anchor id for deep links */
  anchor?: string;
  lede?: string;
}

const { eyebrow, title, anchor, lede } = Astro.props;
const headGap = eyebrow ? 'mt-3' : '';
---

<section class="scroll-mt-24 border-t border-ink/[0.06] pt-12 sm:pt-14" id={anchor}>
  {eyebrow && (
    <p class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-secondary">{eyebrow}</p>
  )}
  <div class={headGap}>
    <h2 class="font-display text-2xl tracking-tight text-ink sm:text-[1.75rem]">{title}</h2>
    {lede && <p class="mt-3 max-w-2xl text-[0.95rem] leading-relaxed text-ink-600">{lede}</p>}
  </div>
  <div class={lede ? 'mt-8' : 'mt-10'}>
    <slot />
  </div>
</section>
