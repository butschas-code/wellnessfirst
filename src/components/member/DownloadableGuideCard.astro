---
import type { DownloadableGuide } from '@/lib/community/types';
import TrackPill from './TrackPill.astro';

interface Props {
  guide: DownloadableGuide;
  trackLabel: string;
}
const { guide, trackLabel } = Astro.props;
const fmt = guide.format.toUpperCase();
---

<article class="card-wfg-sand flex h-full flex-col p-5">
  <div class="flex items-start justify-between gap-2">
    <p class="text-label">Guide · {fmt}</p>
    <TrackPill label={trackLabel} />
  </div>
  <h3 class="mt-3 font-display text-lg text-ink-800 leading-snug">{guide.title}</h3>
  <p class="mt-2 flex-1 text-sm text-ink-500">{guide.fileSizeLabel}</p>
  {guide.state === 'placeholder' && <p class="mt-2 text-sm text-ink-600">Download with launch.</p>}
</article>
