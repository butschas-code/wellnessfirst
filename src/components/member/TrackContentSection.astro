---
import type { CommunityTrackId } from '@/lib/community-tracks';
import type { CommunityTrackContent } from '@/lib/community/types';
import LessonCard from './LessonCard.astro';
import ResourceCard from './ResourceCard.astro';
import WebinarReplayCard from './WebinarReplayCard.astro';
import DownloadableGuideCard from './DownloadableGuideCard.astro';

interface Props {
  label: string;
  trackId: CommunityTrackId;
  anchorId: string;
  content: CommunityTrackContent;
  /** `focus` = track detail page: no anchor jump label, no “this track” link. */
  variant?: 'hub' | 'focus';
  lede?: string;
}
const { label, trackId, anchorId, content, variant = 'hub', lede } = Astro.props;
const lesson = content.lessons[0]!;
const resource = content.resources[0]!;
const replay = content.replays[0]!;
const guide = content.guides[0]!;
---

<section
  id={variant === 'hub' ? anchorId : undefined}
  class:list={[variant === 'hub' && 'scroll-mt-24']}
  aria-labelledby={`${anchorId}-heading`}
>
  <div
    class:list={[
      'flex flex-col gap-2 pb-6 sm:flex-row sm:items-end sm:justify-between sm:gap-4',
      variant === 'hub' && 'border-b border-ink/10',
    ]}
  >
    <div>
      {
        variant === 'focus' ? (
          <h1
            id={`${anchorId}-heading`}
            class="font-display text-3xl text-ink-800 sm:text-4xl"
          >
            {label}
          </h1>
        ) : (
          <h2
            id={`${anchorId}-heading`}
            class="font-display text-2xl text-ink-800 sm:text-3xl"
          >
            {label}
          </h2>
        )
      }
      {lede && variant === 'focus' && <p class="mt-3 max-w-2xl text-ink-600 leading-relaxed">{lede}</p>}
      <p
        class:list={[
          'text-sm text-ink-500',
          lede && variant === 'focus' ? 'mt-4' : 'mt-1',
        ]}
      >
        Sample layout · content arrives with the season
      </p>
    </div>
    {
      variant === 'hub' && (
        <a
          href={`/community/${trackId}`}
          class="link-wfg-ghost text-sm font-medium self-start sm:self-auto"
        >
          This track only
        </a>
      )
    }
  </div>

  <div
    class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4"
  >
    <LessonCard lesson={lesson} trackLabel={label} />
    <ResourceCard resource={resource} trackLabel={label} />
    <WebinarReplayCard replay={replay} trackLabel={label} />
    <DownloadableGuideCard guide={guide} trackLabel={label} />
  </div>
</section>
