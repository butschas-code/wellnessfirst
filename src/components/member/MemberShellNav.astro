---
import { MEMBER_NAV_ITEMS, type MemberNavKey } from '@/lib/member/nav';

interface Props {
  current: MemberNavKey | null;
}
const { current } = Astro.props;

const link = 'rounded-md px-1.5 py-1 text-sm text-ink-600 transition-colors hover:bg-ink/[0.04] hover:text-ink';
const currentCls = 'font-medium text-ink underline decoration-secondary decoration-[2px] underline-offset-[6px]';
---

<nav class="border-b border-ink/[0.07] bg-white/95 backdrop-blur-sm" aria-label="My Wellness Space">
  <div class="container-wfg py-5">
    <div class="flex flex-wrap gap-x-7 gap-y-2.5">
      {
        MEMBER_NAV_ITEMS.map((item) => {
          const on = current === item.key;
          return (
            <a
              href={item.href}
              class:list={[link, on && currentCls]}
              aria-current={on ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </div>
  </div>
</nav>
