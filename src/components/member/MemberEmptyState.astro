---
interface Props {
  title: string;
  description: string;
  href?: string;
  actionLabel?: string;
}

const { title, description, href, actionLabel } = Astro.props;
---

<div class="max-w-lg border-l-[3px] border-secondary/35 pl-5 sm:pl-6">
  <p class="font-display text-lg text-ink">{title}</p>
  <p class="mt-2 text-sm leading-relaxed text-ink-600">{description}</p>
  {
    href && actionLabel && (
      <a class="mt-4 inline-flex text-sm font-medium text-secondary underline decoration-line underline-offset-4 hover:text-ink" href={href}>
        {actionLabel}
      </a>
    )
  }
</div>
