---
import type { CommunityLesson } from '@/lib/community/types';
import TrackPill from './TrackPill.astro';

interface Props {
  lesson: CommunityLesson;
  trackLabel: string;
}
const { lesson, trackLabel } = Astro.props;
const meta = `${lesson.durationMinutes} min${lesson.state === 'placeholder' ? ' · sample' : ''}`;
---

<article class="card-wfg flex h-full flex-col p-5 sm:p-6">
  <div class="flex items-start justify-between gap-2">
    <p class="text-label">Lesson</p>
    <TrackPill label={trackLabel} />
  </div>
  <h3 class="mt-3 font-display text-lg text-ink-800 leading-snug">{lesson.title}</h3>
  <p class="mt-2 line-clamp-3 flex-1 text-sm text-ink-600 leading-relaxed">{lesson.summary}</p>
  <p class="mt-4 text-sm text-ink-500">{meta}</p>
</article>
