---
import { articlePath } from '@/lib/articles';
import { journalCatalogSlug } from '@/lib/articles/journal-catalog-slug';
import { accessBadgeLabel, normalizeAccessLevel } from '@/lib/content/access-level';
import ArticleFavoriteButton from '@/components/articles/ArticleFavoriteButton.astro';
import type { ArticleEntry } from '@/types/content';
import EditorialImageSlot from '@/components/media/EditorialImageSlot.astro';

interface Props {
  entry: ArticleEntry;
  showFeaturedBadge?: boolean;
}

const { entry, showFeaturedBadge } = Astro.props;
const { title, excerpt, category, featured, coverImage } = entry.data;
const accessBadge = accessBadgeLabel(normalizeAccessLevel(entry.data.accessLevel));
const href = articlePath(entry);
const catalogSlug = journalCatalogSlug(entry);
---

<article
  class="group flex h-full min-h-0 flex-col overflow-hidden rounded-2xl border border-ink/10 bg-paper/95 shadow-elevated transition-[transform,box-shadow] duration-300 hover:-translate-y-1 hover:border-secondary/20 hover:shadow-md"
  data-article-category={category}
>
  <a href={href} class="block no-underline" tabindex="-1" aria-hidden="true">
    <div class="relative aspect-[4/3] overflow-hidden border-b border-ink/5 sm:aspect-[3/2]">
      <EditorialImageSlot
        src={coverImage ?? undefined}
        alt={coverImage ? `Cover: ${title}` : ''}
        frame="card"
        ratio="3-2"
        heroVariant="article"
        showPlaceholderWhenEmpty
        fillFrame
        class="absolute inset-0 h-full w-full min-h-0 transition duration-500 group-hover:scale-[1.03]"
      />
    </div>
  </a>
  <div class="flex flex-1 flex-col p-5 sm:p-6 md:p-7">
    <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
      <p class="text-eyebrow text-[0.65rem] text-secondary">{category}</p>
      {
        showFeaturedBadge && featured && (
          <span class="text-[0.65rem] font-medium uppercase tracking-[0.2em] text-secondary">Featured</span>
        )
      }
      {
        accessBadge && (
          <span class="rounded-full border border-ink/12 bg-paper px-2 py-0.5 text-[0.6rem] font-semibold uppercase tracking-wider text-ink-500">
            {accessBadge}
          </span>
        )
      }
    </div>
    <h3 class="mt-2 font-display text-lg font-medium leading-snug text-ink sm:text-xl">
      <a class="text-inherit no-underline transition group-hover:text-secondary" href={href}>{title}</a>
    </h3>
    <p class="mt-3 line-clamp-4 flex-1 text-base leading-relaxed text-charcoal sm:line-clamp-5">
      {excerpt}
    </p>
    <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
      <a
        class="inline-flex w-fit text-sm font-medium text-ink no-underline transition group-hover:text-secondary"
        href={href}
      >
        Read
      </a>
      <ArticleFavoriteButton slug={catalogSlug} variant="card" />
    </div>
  </div>
</article>
