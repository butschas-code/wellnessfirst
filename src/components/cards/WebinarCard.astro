---
import EditorialImageSlot from '@/components/media/EditorialImageSlot.astro';
import { offerPath } from '@/lib/offer-paths';
import { formatDate, formatTime } from '@/lib/format';
import type { WebinarEntry } from '@/types/content';

interface Props {
  entry: WebinarEntry;
}

const { entry } = Astro.props;
const { title, excerpt, coverImage, format, isFree, durationMinutes, startAt, host, primaryLink } = entry.data;
const href = offerPath('webinars', entry);
const eyebrow = `${isFree ? 'Free · ' : ''}${format === 'live' ? 'Live' : 'Replay'} · ${durationMinutes} min`;
const whenLine =
  format === 'live'
    ? `${formatDate(startAt)} at ${formatTime(startAt)} · ${host}`
    : `${formatDate(startAt)} · ${host}`;
const extraHref = primaryLink ?? undefined;
const extraLabel =
  format === 'live'
    ? isFree
      ? 'Save a seat'
      : 'Register'
    : 'Get access';
---

<article
  class="group flex h-full min-h-0 flex-col overflow-hidden rounded-2xl border border-ink/10 bg-paper/95 shadow-elevated transition-[transform,box-shadow] duration-300 hover:-translate-y-1 hover:border-secondary/20 hover:shadow-md"
>
  <a href={href} class="block no-underline" tabindex="-1" aria-hidden="true">
    <div class="relative aspect-[4/3] overflow-hidden border-b border-ink/5 sm:aspect-[3/2]">
      <EditorialImageSlot
        src={coverImage ?? undefined}
        alt={coverImage ? `Session: ${title}` : ''}
        frame="card"
        ratio="3-2"
        heroVariant="webinar"
        showPlaceholderWhenEmpty
        fillFrame
        class="absolute inset-0 h-full w-full min-h-0 transition duration-500 group-hover:scale-[1.03]"
      />
    </div>
  </a>
  <div class="flex flex-1 flex-col p-5 sm:p-6 md:p-7">
    <p class="text-eyebrow text-[0.65rem] text-secondary">{eyebrow}</p>
    <h3 class="mt-2 font-display text-lg font-medium leading-snug text-ink sm:text-xl">
      <a class="text-inherit no-underline transition group-hover:text-secondary" href={href}>{title}</a>
    </h3>
    <p class="mt-3 line-clamp-4 flex-1 text-base leading-relaxed text-charcoal sm:line-clamp-5">
      {excerpt}
    </p>
    <p class="mt-2 text-sm text-ink-500">{whenLine}</p>
    <div class="mt-4 flex flex-col gap-2">
      <a
        class="inline-flex w-fit text-sm font-medium text-ink no-underline transition group-hover:text-secondary"
        href={href}
      >
        Open session
      </a>
      {
        extraHref && (
          <a
            class="inline-flex w-fit text-sm font-medium text-ink/85 no-underline transition hover:text-secondary"
            href={extraHref}
            target={extraHref.startsWith('http') ? '_blank' : undefined}
            rel={extraHref.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {extraLabel}
          </a>
        )
      }
    </div>
  </div>
</article>
