---
/** Four consistent narrative bands for offer detail pages (webinars, consultations, products). */
interface Block {
  id: string;
  title: string;
  body: string;
}

interface Props {
  blocks: Block[];
  intro?: string;
}

const { blocks, intro } = Astro.props;
---

<div class="space-y-12 md:space-y-14">
  {
    intro && (
      <p class="max-w-3xl text-lg leading-relaxed text-ink-600 md:text-xl">{intro}</p>
    )
  }
  {
    blocks.map((b) => (
      <section id={b.id} class="max-w-3xl scroll-mt-24" aria-labelledby={`${b.id}-h`}>
        <h2 id={`${b.id}-h`} class="text-eyebrow text-ink-500">
          {b.title}
        </h2>
        <p class="mt-3 whitespace-pre-line text-ink-600 leading-[1.75] md:text-lg">{b.body}</p>
      </section>
    ))
  }
</div>
