---
import '@/styles/global.css';
import { site } from '@/lib/site';
import MemberShellNav from '@/components/member/MemberShellNav.astro';

interface Props {
  title: string;
  description?: string;
  memberNav?: 'account' | 'library';
}

const { title, description = 'Member sign-in and account for Wellness First Global.', memberNav } = Astro.props;
const pageTitle = `${title} · ${site.name}`;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0a2334" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="flex min-h-screen flex-col bg-paper font-sans text-charcoal antialiased">
    <a
      href="#app-main"
      class="fixed left-3 top-3 z-[100] -translate-y-24 bg-ink px-3 py-2 text-sm text-white opacity-0 transition-transform focus:translate-y-0 focus:opacity-100 focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-ink"
    >
      Skip to content
    </a>
    <header class="border-b border-ink/10 bg-white">
      <div class="container-wfg flex h-14 items-center justify-between gap-4 sm:h-16">
        <div class="flex shrink-0 items-center gap-2 sm:gap-2.5">
          <a
            href="/"
            class="flex rounded-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink/25"
            aria-label="Wellness First Global, home"
          >
            <img
              src="/brand/wellness-first-logo-trans.png"
              alt=""
              width="1871"
              height="1258"
              class="h-7 w-auto max-h-8 max-w-[7.5rem] object-contain object-left sm:h-8 sm:max-h-9 sm:max-w-[9rem]"
              loading="eager"
              decoding="async"
            />
          </a>
          <a
            href="/"
            class="font-sans text-[0.6rem] font-semibold uppercase leading-tight tracking-[0.2em] text-ink sm:text-[0.7rem] whitespace-nowrap rounded focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink/25"
          >
            Wellness First
          </a>
        </div>
        <span class="text-sm font-medium uppercase tracking-[0.12em] text-ink-500">Member</span>
      </div>
    </header>
    {memberNav && <MemberShellNav current={memberNav} />}
    <main id="app-main" class="flex-1" tabindex="-1">
      <slot />
    </main>
    <footer class="mt-auto border-t border-ink/10 py-6">
      <div class="container-wfg flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <a class="link-wfg-ghost text-sm" href="/">← Public site</a>
        <a class="link-wfg-ghost text-sm" href="/contact">Help</a>
      </div>
    </footer>
  </body>
</html>
