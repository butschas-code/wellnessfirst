---
import CmsLayout from '@/components/cms/CmsLayout.astro';

interface Props {
  title: string;
  description?: string;
  active: 'dashboard' | 'articles' | 'webinars' | 'consultations' | 'products' | 'site-pages';
}

const { title, description, active } = Astro.props;
---

<CmsLayout title={title} description={description} active={active}>
  <div class="container-wfg max-w-5xl py-8 md:py-10">
    <div
      id="cms-gate"
      class="rounded-xl border border-ink/10 bg-white p-8 text-center text-ink-600 shadow-elevated"
    >
      Checking access…
    </div>
    <div
      id="cms-gate-denied"
      class="hidden rounded-xl border border-amber-200/90 bg-amber-50/95 p-8 text-ink-800 shadow-elevated"
    >
      <h2 class="font-display text-xl text-ink">CMS hub unavailable</h2>
      <p class="mt-3 text-sm leading-relaxed">
        This page needs Supabase auth in the browser (<code class="rounded bg-white px-1.5 py-0.5 text-ink">PUBLIC_SUPABASE_URL</code> and <code class="rounded bg-white px-1.5 py-0.5 text-ink">PUBLIC_SUPABASE_ANON_KEY</code>). If those are set, your signed-in email must be listed in <code class="rounded bg-white px-1.5 py-0.5 text-ink">PUBLIC_CMS_ALLOWED_EMAILS</code> (comma-separated). Update the deployment environment and sign in again.
      </p>
      <p class="mt-4 text-sm text-ink-600">
        You can still edit content in the <a class="font-medium text-secondary underline" href="/admin/">Decap editor</a> if GitHub authentication is configured for this repository (independent of Supabase).
      </p>
      <p class="mt-6">
        <a class="btn-secondary inline-flex" href="/app/sign-in">Sign in with a different account</a>
      </p>
    </div>
    <div id="cms-gate-allowed" class="hidden">
      <slot />
    </div>
  </div>
  <script>
    import { initCmsAuthGate } from '@/scripts/cms-guard';
    initCmsAuthGate();
  </script>
</CmsLayout>
