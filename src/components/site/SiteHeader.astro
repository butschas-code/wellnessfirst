---
import { getPublished } from '@/lib/content-filters';
import { primaryNav } from '@/lib/navigation';

const pathname = Astro.url.pathname;

function navItemActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  if (href === '/login') return pathname === '/login' || pathname === '/signup';
  return pathname === href || pathname.startsWith(`${href}/`);
}

const navPages = (await getPublished('pages'))
  .filter((e) => e.data.showInNav)
  .sort((a, b) => a.data.order - b.data.order)
  .map((e) => ({
    href: `/p/${e.id}`,
    label: e.data.navLabel ?? e.data.title,
  }));
const menuId = 'wfg-mobile-menu';
---

<!-- Floating pill nav: sticky, zero layout height — abexis-style long rounded bar -->
<header class="pointer-events-none sticky top-0 z-40 h-0 overflow-visible">
  <div
    class="px-4 sm:px-6 md:px-8"
    style={{ paddingTop: 'max(0.75rem, env(safe-area-inset-top, 0px))' }}
  >
    <div
      class="pointer-events-auto mx-auto flex w-full max-w-4xl items-center justify-between gap-2 rounded-full border border-primary/10 bg-white px-3 py-2 shadow-md shadow-primary/[0.06] sm:gap-3 sm:px-4 md:py-2.5"
    >
      <div class="flex min-w-0 shrink-0 items-center gap-2 sm:gap-2.5">
        <a
          href="/"
          class="flex shrink-0 rounded-full focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary/40"
          aria-label="Wellness First Global, home"
        >
          <img
            src="/brand/wellness-first-logo-trans.png"
            alt=""
            width="1871"
            height="1258"
            class="h-7 w-auto max-h-9 max-w-[7.5rem] object-contain object-left sm:h-8 sm:max-h-10 sm:max-w-[9rem] md:max-w-[10rem]"
            loading="eager"
            decoding="async"
          />
        </a>
        <a
          href="/"
          class="font-sans text-[0.6rem] font-semibold uppercase leading-tight tracking-[0.2em] text-primary sm:text-[0.7rem] md:text-xs whitespace-nowrap rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary/40"
        >
          Wellness First
        </a>
      </div>

      <nav class="hidden min-w-0 flex-1 items-center justify-end gap-0.5 lg:flex" aria-label="Primary">
        {primaryNav.map((item) => {
          const active = navItemActive(item.href);
          const iconOnly = item.iconOnly === true;
          const baseCls = iconOnly
            ? 'inline-flex shrink-0 items-center justify-center rounded-full px-2.5 py-1.5 transition-colors duration-200 xl:px-3'
            : 'shrink-0 rounded-full px-3 py-1.5 text-sm font-medium tracking-[-0.01em] transition-colors duration-200 xl:px-4';
          const toneCls = active
            ? 'bg-primary text-white'
            : 'text-charcoal hover:bg-primary/[0.06] hover:text-primary';
          return iconOnly ? (
            <a
              class:list={[baseCls, toneCls]}
              href={item.href}
              aria-current={active ? 'page' : undefined}
              aria-label={item.label}
            >
              <svg
                class="h-[1.125rem] w-[1.125rem] shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M17.982 18.725A7.488 7.488 0 0012 15.75a7.488 7.488 0 00-5.982 2.975m11.963 0a9 9 0 10-11.963 0m11.963 0A8.966 8.966 0 0112 21a8.966 8.966 0 01-5.982-2.275M15 9.75a3 3 0 11-6 0 3 3 0 016 0z"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          ) : (
            <a
              class:list={[baseCls, toneCls, 'text-sm font-medium tracking-[-0.01em]']}
              href={item.href}
              aria-current={active ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })}
        {navPages.map((item) => {
          const active = navItemActive(item.href);
          return (
            <a
              class:list={[
                'shrink-0 rounded-full px-3 py-1.5 text-sm font-medium tracking-[-0.01em] transition-colors duration-200 xl:px-4',
                active
                  ? 'bg-primary text-white'
                  : 'text-charcoal hover:bg-primary/[0.06] hover:text-primary',
              ]}
              href={item.href}
              aria-current={active ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <button
        type="button"
        class="flex min-h-10 shrink-0 items-center justify-center gap-1.5 rounded-full border border-primary/10 bg-white px-3 py-1.5 text-sm font-medium text-primary transition-colors hover:bg-primary/5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary lg:hidden"
        aria-expanded="false"
        aria-controls={menuId}
        id="wfg-menu-open"
        aria-label="Open menu"
      >
        <span>Menu</span>
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true" class="text-primary">
          <path
            d="M3 5h14M3 10h14M3 15h14"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
          />
        </svg>
      </button>
    </div>

    <div
      id={menuId}
      class="pointer-events-auto relative z-50 mx-auto mt-2 hidden w-full max-w-4xl overflow-hidden rounded-2xl border border-primary/10 bg-white shadow-lg shadow-primary/10 lg:hidden"
      role="dialog"
      aria-modal="true"
      aria-label="Site menu"
      aria-hidden="true"
      data-wfg-menu
    >
      <div class="flex items-center justify-between border-b border-primary/8 px-3 py-2.5 sm:px-4">
        <span class="font-display text-base text-primary sm:text-lg">Menu</span>
        <button
          type="button"
          class="min-h-11 min-w-11 items-center justify-center rounded-full p-2 text-charcoal transition-colors hover:bg-primary/5 hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary inline-flex"
          id="wfg-menu-close"
          aria-label="Close menu"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path
              d="M5 5l10 10M15 5L5 15"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
            />
          </svg>
        </button>
      </div>
      <nav class="max-h-[min(70vh,28rem)] overflow-y-auto px-2 py-2" aria-label="Mobile">
        {primaryNav.map((item) =>
          item.iconOnly ? (
            <a
              class="flex min-h-12 items-center gap-2 rounded-xl px-3 py-2 text-base text-ink transition-colors hover:bg-primary/5 hover:text-primary active:bg-primary/8"
              href={item.href}
              data-wfg-menu-link
              aria-label={item.label}
            >
              <svg
                class="h-6 w-6 shrink-0 text-current"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M17.982 18.725A7.488 7.488 0 0012 15.75a7.488 7.488 0 00-5.982 2.975m11.963 0a9 9 0 10-11.963 0m11.963 0A8.966 8.966 0 0112 21a8.966 8.966 0 01-5.982-2.275M15 9.75a3 3 0 11-6 0 3 3 0 016 0z"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          ) : (
            <a
              class="flex min-h-12 items-center rounded-xl px-3 py-2 text-base text-ink transition-colors hover:bg-primary/5 hover:text-primary active:bg-primary/8"
              href={item.href}
              data-wfg-menu-link
            >
              {item.label}
            </a>
          ),
        )}
        {navPages.map((item) => (
          <a
            class="flex min-h-12 items-center rounded-xl px-3 py-2 text-base text-ink transition-colors hover:bg-primary/5 hover:text-primary active:bg-primary/8"
            href={item.href}
            data-wfg-menu-link
          >
            {item.label}
          </a>
        ))}
      </nav>
      <div class="border-t border-primary/8 p-3 pt-2 sm:p-4 sm:pt-3 pb-[max(0.75rem,env(safe-area-inset-bottom,0px))]">
        <a class="btn-primary w-full justify-center" href="/webinars">Webinars</a>
        <a class="btn-secondary mt-2 w-full justify-center" href="/contact">Contact</a>
      </div>
    </div>
  </div>
</header>

<script>
  const root = document.querySelector('[data-wfg-menu]') as HTMLElement | null;
  const openBtn = document.getElementById('wfg-menu-open');
  const closeBtn = document.getElementById('wfg-menu-close');
  if (root && openBtn) {
    const links = () => document.querySelectorAll<HTMLElement>('[data-wfg-menu-link]');
    const setOpen = (open: boolean) => {
      root.classList.toggle('hidden', !open);
      openBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
      root.setAttribute('aria-hidden', open ? 'false' : 'true');
      document.body.style.overflow = open ? 'hidden' : '';
      if (open) closeBtn?.focus();
      else openBtn.focus();
    };
    openBtn.addEventListener('click', () => {
      setOpen(root.classList.contains('hidden'));
    });
    closeBtn?.addEventListener('click', () => setOpen(false));
    links().forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !root.classList.contains('hidden')) setOpen(false);
    });
  }
</script>
