---
import { site } from '@/lib/site';
import Container from '@/components/layout/Container.astro';
import NewsletterCta from '@/components/conversion/NewsletterCta.astro';
import { primaryNav } from '@/lib/navigation';

const year = new Date().getUTCFullYear();
const mail = site.contactEmail;
---

<footer
  class="mt-auto border-t border-primary/10 bg-white/95 py-12 md:py-16 pb-[max(3rem,env(safe-area-inset-bottom,0.75rem))] md:pb-[max(4rem,env(safe-area-inset-bottom,0.75rem))]"
>
  <Container>
    <div class="grid gap-10 md:grid-cols-12 md:gap-8 lg:gap-10">
      <div class="md:col-span-5">
        <p class="font-display text-2xl tracking-tight text-ink md:text-3xl">{site.name}</p>
        <p class="mt-3 max-w-md text-sm leading-relaxed text-charcoal sm:text-base">
          {site.brandLine}
        </p>
        <a class="link-wfg-ghost mt-4 inline-block text-sm" href={`mailto:${mail}`}>
          {mail}
        </a>
      </div>
      <div class="md:col-span-3">
        <p class="text-sm font-medium text-ink-500">On this site</p>
        <ul class="mt-3 space-y-2.5" role="list">
          {primaryNav.map((item) => (
            <li>
              <a class="text-sm text-ink underline decoration-line decoration-1 underline-offset-4 transition-colors hover:text-secondary" href={item.href}>
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a class="text-sm text-ink underline decoration-line decoration-1 underline-offset-4 transition-colors hover:text-secondary" href="/p/editorial-standards">Editorial standards</a>
          </li>
          <li>
            <a class="text-sm text-ink underline decoration-line decoration-1 underline-offset-4 transition-colors hover:text-secondary" href="/app/sign-in">Member sign-in</a>
          </li>
        </ul>
      </div>
      <div class="md:col-span-4">
        <p class="text-sm font-medium text-ink-500">Email</p>
        <NewsletterCta
          id="footer-newsletter"
          compact
          heading="Updates"
          sub="New articles and session dates, occasionally. Unsubscribe in one step."
          submitLabel="Sign up"
        />
      </div>
    </div>
    <div
      class="mt-10 flex flex-col gap-4 border-t border-ink/10 pt-6 text-sm text-ink-500 md:flex-row md:flex-wrap md:items-center md:justify-between"
    >
      <p class="text-sm text-ink-500">© {year} {site.name}. All rights reserved.</p>
      <ul class="flex flex-wrap gap-x-6 gap-y-1 text-sm" role="list">
        <li>
          <a class="link-wfg-ghost" href="/legal/privacy">Privacy</a>
        </li>
        <li>
          <a class="link-wfg-ghost" href="/legal/terms">Terms</a>
        </li>
        <li>
          <a class="link-wfg-ghost" href="/legal/imprint">Imprint</a>
        </li>
        <li>
          <a class="link-wfg-ghost" href="/contact">Contact</a>
        </li>
      </ul>
    </div>
  </Container>
</footer>
