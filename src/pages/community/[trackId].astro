---
import AppLayout from '@/components/app/AppLayout.astro';
import { COMMUNITY_TRACKS, type CommunityTrackId } from '@/lib/community-tracks';
import { getCommunityTrackContent, isCommunityTrackId } from '@/lib/community/placeholder-data';
import { TRACK_CARD_LEDE } from '@/lib/community/track-summaries';
import TrackContentSection from '@/components/member/TrackContentSection.astro';

export function getStaticPaths() {
  return COMMUNITY_TRACKS.map((t) => ({
    params: { trackId: t.id },
  }));
}

const raw = Astro.params.trackId;
if (!raw || !isCommunityTrackId(raw)) {
  return Astro.redirect('/community/dashboard');
}
const trackId: CommunityTrackId = raw;
const track = COMMUNITY_TRACKS.find((t) => t.id === trackId)!;
const content = getCommunityTrackContent(trackId);
const lede = TRACK_CARD_LEDE[trackId];
---

<AppLayout
  title={track.label}
  description={`Member track · ${track.label}`}
  memberShell={true}
  memberNav={null}
>
  <div class="container-wfg py-10 sm:py-14">
    <p id="comm-track-state" class="text-sm text-ink-500">Loading…</p>

    <div id="comm-track-panel" class="hidden">
      <p class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-ink-500">
        <a class="link-wfg-ghost font-medium text-secondary" href="/my-wellness-space">My Wellness Space</a>
        <span class="text-taupe-300" aria-hidden="true">·</span>
        <a class="link-wfg-ghost" href="/community/dashboard">Library</a>
      </p>
      <div class="mt-8 sm:mt-10">
        <TrackContentSection
          label={track.label}
          trackId={trackId}
          anchorId={`page-${trackId}`}
          content={content}
          variant="focus"
          lede={lede}
        />
      </div>
      <p class="mt-10 text-sm text-ink-500">
        <button type="button" id="comm-track-signout" class="link-wfg-ghost">Sign out</button>
      </p>
    </div>
  </div>
</AppLayout>
<script>
  import { guardSessionOrRedirect } from '@/lib/app/guardSession';
  import { getSupabaseBrowser, isSupabaseConfigured } from '@/lib/supabase/browser';

  const state = document.getElementById('comm-track-state');
  const panel = document.getElementById('comm-track-panel');

  (async () => {
    if (!isSupabaseConfigured()) {
      if (state) {
        state.textContent =
          'Supabase is not configured. Set PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY, then rebuild.';
      }
      return;
    }
    const session = await guardSessionOrRedirect();
    if (!session) return;
    if (state) state.classList.add('hidden');
    if (panel) panel.classList.remove('hidden');
  })();

  document.getElementById('comm-track-signout')?.addEventListener('click', async () => {
    if (!isSupabaseConfigured()) return;
    const supabase = getSupabaseBrowser();
    await supabase.auth.signOut();
    window.location.replace('/login');
  });
</script>
