---
/**
 * Supabase Dashboard: Email enabled; reset redirect URL must include `/reset-password`.
 * Configure **Authentication → URL configuration → Redirect URLs** for each origin.
 */
import BaseLayout from '@/components/layout/BaseLayout.astro';
---

<BaseLayout
  title="Forgot password · Wellness First Global"
  description="Reset access to My Wellness Space."
  noIndex={true}
  bodyClass=""
>
  <div class="container-wfg max-w-md py-12 sm:py-16">
    <p class="text-eyebrow text-secondary">Members</p>
    <h1 class="font-display mt-2 text-3xl tracking-tight text-ink-800 sm:text-4xl">Forgot password</h1>
    <p class="mt-3 text-ink-600 leading-relaxed">
      We will send a quiet note with a link to choose a new password. Nothing happens until you open it.
    </p>

    <form id="wfg-forgot-form" class="mt-10 grid gap-6">
      <div>
        <label for="wfg-fp-email" class="label-wfg">Email</label>
        <input id="wfg-fp-email" name="email" type="email" autocomplete="email" required class="input-wfg" />
      </div>

      <p id="wfg-fp-error" class="hidden rounded-lg bg-red-50 px-3 py-2 text-sm text-red-900" role="alert"></p>
      <p id="wfg-fp-status" class="hidden rounded-lg bg-white px-3 py-2 text-sm text-ink-700 ring-1 ring-ink/10" role="status"></p>

      <button type="submit" id="wfg-fp-submit" class="btn-primary min-h-11 w-full justify-center">
        Send reset link
      </button>
    </form>

    <p class="mt-10 text-sm text-ink-500">
      <a class="text-secondary underline decoration-line underline-offset-2" href="/login">Back to sign in</a>
    </p>

    <div
      id="wfg-config-missing"
      class="mt-10 hidden border-t border-dashed border-ink/25 pt-6 text-sm text-ink-600 leading-relaxed"
    />
  </div>
</BaseLayout>

<script>
  import { getSupabaseBrowser, isSupabaseConfigured } from '@/lib/supabase/browser';
  import { formatAuthError } from '@/lib/auth/auth-errors';
  import { authEmailRedirectUrl } from '@/lib/auth/email-redirect';

  const missing = document.getElementById('wfg-config-missing');
  if (missing && !isSupabaseConfigured()) {
    missing.classList.remove('hidden');
    missing.textContent =
      'Password reset needs Supabase keys in your environment (PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY).';
  }

  const form = document.getElementById('wfg-forgot-form') as HTMLFormElement | null;
  const emailInput = document.getElementById('wfg-fp-email') as HTMLInputElement | null;
  const errEl = document.getElementById('wfg-fp-error');
  const statusEl = document.getElementById('wfg-fp-status');
  const submitBtn = document.getElementById('wfg-fp-submit') as HTMLButtonElement | null;

  const qpEmail = new URLSearchParams(window.location.search).get('email');
  if (qpEmail && emailInput) emailInput.value = qpEmail.trim();

  function setLoading(loading: boolean) {
    if (!submitBtn) return;
    submitBtn.disabled = loading;
    submitBtn.setAttribute('aria-busy', loading ? 'true' : 'false');
    submitBtn.textContent = loading ? 'Sending…' : 'Send reset link';
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!isSupabaseConfigured() || !form || !errEl || !statusEl) return;
    errEl.classList.add('hidden');
    statusEl.classList.add('hidden');

    const fd = new FormData(form);
    const email = String(fd.get('email') ?? '').trim().toLowerCase();
    if (!email) {
      errEl.textContent = 'Please enter the email you use with us.';
      errEl.classList.remove('hidden');
      return;
    }

    setLoading(true);
    try {
      const supabase = getSupabaseBrowser();
      const { error } = await supabase.auth.resetPasswordForEmail(email, {
        redirectTo: authEmailRedirectUrl('/reset-password'),
      });
      if (error) {
        errEl.textContent = formatAuthError(error);
        errEl.classList.remove('hidden');
        return;
      }
      statusEl.textContent =
        'If we recognise this address, a reset message is on its way. It can take a minute — quiet folders, spam, and promotions are worth a glance.';
      statusEl.classList.remove('hidden');
    } catch {
      errEl.textContent = formatAuthError(null);
      errEl.classList.remove('hidden');
    } finally {
      setLoading(false);
    }
  });
</script>
