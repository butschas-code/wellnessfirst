---
/**
 * Supabase Dashboard: add `/reset-password` to Redirect URLs; recovery links use Site URL + this path.
 */
import BaseLayout from '@/components/layout/BaseLayout.astro';
---

<BaseLayout
  title="New password · Wellness First Global"
  description="Choose a new password for My Wellness Space."
  noIndex={true}
  bodyClass=""
>
  <div class="container-wfg max-w-md py-12 sm:py-16">
    <p class="text-eyebrow text-secondary">Members</p>
    <h1 class="font-display mt-2 text-3xl tracking-tight text-ink-800 sm:text-4xl">Choose a new password</h1>
    <p class="mt-3 text-ink-600 leading-relaxed">
      This page opens from the link in your email. When you save, we return you to sign in with the new phrase.
    </p>

    <p id="wfg-rp-wait" class="mt-10 text-sm text-ink-500">Preparing a secure session from your link…</p>

    <form id="wfg-rp-form" class="mt-10 hidden grid gap-6">
      <div>
        <label for="wfg-rp-pw" class="label-wfg">New password</label>
        <input
          id="wfg-rp-pw"
          name="password"
          type="password"
          autocomplete="new-password"
          required
          minlength="8"
          maxlength="128"
          class="input-wfg"
        />
      </div>
      <div>
        <label for="wfg-rp-pw2" class="label-wfg">Confirm password</label>
        <input
          id="wfg-rp-pw2"
          name="password2"
          type="password"
          autocomplete="new-password"
          required
          minlength="8"
          class="input-wfg"
        />
      </div>

      <p id="wfg-rp-error" class="hidden rounded-lg bg-red-50 px-3 py-2 text-sm text-red-900" role="alert"></p>

      <button type="submit" id="wfg-rp-submit" class="btn-primary min-h-11 w-full justify-center">
        Save password
      </button>
    </form>

    <p id="wfg-rp-bad-link" class="mt-10 hidden text-sm text-ink-600 leading-relaxed">
      This link may have expired or already been used.
      <a class="text-secondary underline decoration-line underline-offset-2" href="/forgot-password">Request a fresh one</a>
      .
    </p>

    <p class="mt-10 text-sm text-ink-500">
      <a class="text-secondary underline decoration-line underline-offset-2" href="/login">Back to sign in</a>
    </p>

    <div
      id="wfg-config-missing"
      class="mt-10 hidden border-t border-dashed border-ink/25 pt-6 text-sm text-ink-600 leading-relaxed"
    />
  </div>
</BaseLayout>

<script>
  import { getSupabaseBrowser, isSupabaseConfigured } from '@/lib/supabase/browser';
  import { formatAuthError } from '@/lib/auth/auth-errors';
  import { LOGIN_PATH } from '@/lib/auth/constants';

  const missing = document.getElementById('wfg-config-missing');
  if (missing && !isSupabaseConfigured()) {
    missing.classList.remove('hidden');
    missing.textContent =
      'Reset is not configured here. Add PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY, then try again.';
  }

  const waitEl = document.getElementById('wfg-rp-wait');
  const formEl = document.getElementById('wfg-rp-form') as HTMLFormElement | null;
  const badLink = document.getElementById('wfg-rp-bad-link');
  const errEl = document.getElementById('wfg-rp-error');
  const submitBtn = document.getElementById('wfg-rp-submit') as HTMLButtonElement | null;
  const pw2 = document.getElementById('wfg-rp-pw2') as HTMLInputElement | null;

  function revealForm() {
    waitEl?.classList.add('hidden');
    formEl?.classList.remove('hidden');
  }

  function showBadLink() {
    waitEl?.classList.add('hidden');
    badLink?.classList.remove('hidden');
  }

  function setLoading(loading: boolean) {
    if (!submitBtn) return;
    submitBtn.disabled = loading;
    submitBtn.setAttribute('aria-busy', loading ? 'true' : 'false');
    submitBtn.textContent = loading ? 'Saving…' : 'Save password';
  }

  if (isSupabaseConfigured()) {
    const supabase = getSupabaseBrowser();

    let unlocked = false;
    const revealOnce = () => {
      if (unlocked) return;
      unlocked = true;
      revealForm();
    };

    supabase.auth.onAuthStateChange((event) => {
      if (event === 'PASSWORD_RECOVERY') revealOnce();
    });

    (async () => {
      const {
        data: { session },
      } = await supabase.auth.getSession();
      if (session) revealOnce();

      window.setTimeout(() => {
        if (!unlocked) showBadLink();
      }, 12000);
    })();

    formEl?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!formEl || !errEl) return;
      errEl.classList.add('hidden');

      const fd = new FormData(formEl);
      const a = String(fd.get('password') ?? '');
      const b = pw2?.value ?? String(fd.get('password2') ?? '');
      if (a.length < 8) {
        errEl.textContent = 'Please use at least eight characters.';
        errEl.classList.remove('hidden');
        return;
      }
      if (a !== b) {
        errEl.textContent = 'The two fields do not match — take a slow second look.';
        errEl.classList.remove('hidden');
        return;
      }

      setLoading(true);
      try {
        const { error } = await supabase.auth.updateUser({ password: a });
        if (error) {
          errEl.textContent = formatAuthError(error);
          errEl.classList.remove('hidden');
          setLoading(false);
          return;
        }
        await supabase.auth.signOut();
        window.location.replace(`${LOGIN_PATH}?reset=done`);
      } catch {
        errEl.textContent = formatAuthError(null);
        errEl.classList.remove('hidden');
        setLoading(false);
      }
    });
  }
</script>
