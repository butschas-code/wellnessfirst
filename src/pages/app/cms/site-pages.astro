---
import { getCollection } from 'astro:content';
import CmsPageShell from '@/components/cms/CmsPageShell.astro';

const items = (await getCollection('pages')).sort((a, b) => a.data.order - b.data.order);
---

<CmsPageShell title="Site pages" description="List of flexible site pages (excluding reserved routes)." active="site-pages">
  <h1 class="font-display text-2xl text-ink md:text-3xl">Site pages</h1>
  <p class="mt-2 text-sm text-ink-600">Source: <code class="rounded bg-ink/5 px-1">src/content/pages</code> · public URLs are <code class="rounded bg-ink/5 px-1">/p/&#123;id&#125;</code> (the <code class="rounded bg-ink/5 px-1">about</code> and <code class="rounded bg-ink/5 px-1">community</code> slugs are reserved for dedicated templates).</p>
  <div class="mt-6 overflow-x-auto rounded-xl border border-ink/10 bg-white shadow-elevated">
    <table class="w-full min-w-[32rem] text-left text-sm">
      <thead class="border-b border-ink/10 bg-paper-200/50 text-xs font-semibold uppercase tracking-wider text-ink-600">
        <tr>
          <th class="px-4 py-3">Title</th>
          <th class="px-4 py-3">Id (slug)</th>
          <th class="px-4 py-3">Nav</th>
          <th class="px-4 py-3">Draft</th>
          <th class="px-4 py-3">View</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ink/10 text-ink-800">
        {
          items.map((e) => (
            <tr>
              <td class="px-4 py-3 font-medium text-ink">{e.data.title}</td>
              <td class="px-4 py-3 font-mono text-xs text-ink-600">{e.id}</td>
              <td class="px-4 py-3 text-ink-600">{e.data.showInNav ? (e.data.navLabel ?? e.data.title) : '—'}</td>
              <td class="px-4 py-3">{e.data.draft ? 'Yes' : '—'}</td>
              <td class="px-4 py-3">
                <a class="text-secondary underline hover:text-ink" href={`/p/${e.id}`} target="_blank" rel="noreferrer">
                  Live
                </a>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</CmsPageShell>
