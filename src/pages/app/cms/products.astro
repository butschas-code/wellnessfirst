---
import { getCollection } from 'astro:content';
import CmsPageShell from '@/components/cms/CmsPageShell.astro';

const items = (await getCollection('products')).sort((a, b) => a.data.order - b.data.order);

const path = (e: (typeof items)[0]) => `/products/${e.data.slug ?? e.id}`;
---

<CmsPageShell title="Products" description="List of product entries." active="products">
  <h1 class="font-display text-2xl text-ink md:text-3xl">Products</h1>
  <p class="mt-2 text-sm text-ink-600">Source: <code class="rounded bg-ink/5 px-1">src/content/products</code></p>
  <div class="mt-6 overflow-x-auto rounded-xl border border-ink/10 bg-white shadow-elevated">
    <table class="w-full min-w-[40rem] text-left text-sm">
      <thead class="border-b border-ink/10 bg-paper-200/50 text-xs font-semibold uppercase tracking-wider text-ink-600">
        <tr>
          <th class="px-4 py-3">Name</th>
          <th class="px-4 py-3">Id</th>
          <th class="px-4 py-3">Category</th>
          <th class="px-4 py-3">Availability</th>
          <th class="px-4 py-3">Draft</th>
          <th class="px-4 py-3">View</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ink/10 text-ink-800">
        {
          items.map((e) => (
            <tr>
              <td class="px-4 py-3 font-medium text-ink">{e.data.name}</td>
              <td class="px-4 py-3 font-mono text-xs text-ink-600">{e.id}</td>
              <td class="px-4 py-3 text-ink-600">{e.data.category}</td>
              <td class="px-4 py-3 capitalize text-ink-600">{e.data.availability}</td>
              <td class="px-4 py-3">{e.data.draft ? 'Yes' : '—'}</td>
              <td class="px-4 py-3">
                <a class="text-secondary underline hover:text-ink" href={path(e)} target="_blank" rel="noreferrer">
                  Live
                </a>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</CmsPageShell>
