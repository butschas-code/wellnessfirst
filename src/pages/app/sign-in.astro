---
import AppLayout from '@/components/app/AppLayout.astro';
---

<AppLayout title="Sign in" description="Sign in to the Wellness First Global member area.">
  <div class="container-wfg max-w-md py-12 sm:py-16">
    <h1 class="font-display text-3xl text-ink-800">Sign in</h1>
    <p class="mt-2 text-ink-600">Email and password for the member area (separate from the public newsletter list).</p>

    <form id="app-signin-form" class="mt-8 grid max-w-md gap-5">
      <div>
        <label for="app-signin-email" class="label-wfg">Email</label>
        <input
          id="app-signin-email"
          name="email"
          type="email"
          autocomplete="email"
          required
          class="input-wfg"
        />
      </div>
      <div>
        <label for="app-signin-password" class="label-wfg">Password</label>
        <input
          id="app-signin-password"
          name="password"
          type="password"
          autocomplete="current-password"
          required
          minlength="6"
          class="input-wfg"
        />
      </div>
      <p id="app-signin-error" class="hidden text-sm text-red-800" role="alert"></p>
      <button type="submit" class="btn-primary w-full min-h-11">Sign in</button>
    </form>

    <p class="mt-6 text-sm text-ink-500">
      <a class="text-secondary underline decoration-line" href="/app/sign-up">Create an account</a>
    </p>

    <div
      id="app-config-missing"
      class="mt-8 hidden border-0 border-t-2 border-dashed border-ink/30 bg-white py-4 text-sm text-charcoal leading-relaxed"
    />
  </div>
</AppLayout>
<script>
  import { getSupabaseBrowser, isSupabaseConfigured } from '@/lib/supabase/browser';
  import { safeMemberNextParam } from '@/lib/app/redirects';

  const box = document.getElementById('app-config-missing');
  if (box && !isSupabaseConfigured()) {
    box.classList.remove('hidden');
    box.textContent =
      'Supabase is not configured. Copy .env.example to .env, set PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY, then restart the dev server.';
  }

  const form = document.getElementById('app-signin-form') as HTMLFormElement | null;
  const err = document.getElementById('app-signin-error');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!isSupabaseConfigured() || !form || !err) return;
    err.classList.add('hidden');
    const fd = new FormData(form);
    const email = String(fd.get('email') ?? '').trim();
    const password = String(fd.get('password') ?? '');
    const supabase = getSupabaseBrowser();
    const { error } = await supabase.auth.signInWithPassword({ email, password });
    if (error) {
      err.textContent = error.message;
      err.classList.remove('hidden');
      return;
    }
    const sp = new URLSearchParams(window.location.search);
    const next = safeMemberNextParam(sp.get('next'));
    window.location.replace(next);
  });
</script>
