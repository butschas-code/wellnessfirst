---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import MarketingHero from '@/components/layout/MarketingHero.astro';
import HomePageFooter from '@/components/home/HomePageFooter.astro';
import { marketingPageLayout } from '@/lib/marketing-page';
import RichText from '@/components/content/RichText.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import ArticleCard from '@/components/cards/ArticleCard.astro';
import ArticleCta from '@/components/content/ArticleCta.astro';
import ArticleRelatedOffers from '@/components/content/ArticleRelatedOffers.astro';
import CommunitySpine from '@/components/community/CommunitySpine.astro';
import { publishedOnly } from '@/lib/content-filters';
import { formatDate } from '@/lib/format';
import ArticleFavoriteButton from '@/components/articles/ArticleFavoriteButton.astro';
import ArticleReflectionPanel from '@/components/articles/ArticleReflectionPanel.astro';
import AccessGate from '@/components/access/AccessGate.astro';
import { getArticleByParamSlug, fillRelatedArticles, articlePath } from '@/lib/articles';
import { journalCatalogSlug } from '@/lib/articles/journal-catalog-slug';
import { normalizeAccessLevel } from '@/lib/content/access-level';
import { articleJsonLd } from '@/lib/seo';
import type { ProductEntry, WebinarEntry, ConsultationEntry } from '@/types/content';
export async function getStaticPaths() {
  const items = await getCollection('articles', publishedOnly);
  const used = new Map<string, string>();
  for (const post of items) {
    const key = post.data.slug ?? post.id;
    const prev = used.get(key);
    if (prev && prev !== post.id) {
      throw new Error(`Duplicate public article slug or id "${key}" (${prev} vs ${post.id})`);
    }
    used.set(key, post.id);
  }
  return items.map((post) => ({ params: { slug: post.data.slug ?? post.id } }));
}

const { slug } = Astro.params;
const allArticles = await getCollection('articles', publishedOnly);
const post = getArticleByParamSlug(allArticles, slug!);
if (!post) throw new Error(`Article not found: ${slug}`);

const {
  title,
  excerpt,
  author,
  publishedAt,
  updatedAt,
  category,
  subtitle,
  seoTitle,
  seoDescription,
  coverImage,
  coverImageFit,
  relatedProducts: relatedProductIds,
  relatedWebinar: relatedWebinarId,
  relatedConsultation: relatedConsultationId,
} = post.data;

const accessLevel = normalizeAccessLevel(post.data.accessLevel);
const allowFavoriteReflection = accessLevel === 'public' || accessLevel === 'member';
const renderPublic = accessLevel === 'public' ? await render(post) : null;
const Content = renderPublic?.Content;

const metaTitle = seoTitle ?? title;
const metaDescription = seoDescription ?? excerpt;
const publicPath = articlePath(post);
const catalogSlug = journalCatalogSlug(post);

const productEntries: ProductEntry[] = [];
for (const id of relatedProductIds) {
  const p = await getEntry('products', id);
  if (p && publishedOnly(p)) productEntries.push(p);
}

let webinar: WebinarEntry | undefined;
if (relatedWebinarId) {
  const w = await getEntry('webinars', relatedWebinarId);
  if (w && publishedOnly(w)) webinar = w;
}

let consultation: ConsultationEntry | undefined;
if (relatedConsultationId) {
  const c = await getEntry('consultations', relatedConsultationId);
  if (c && publishedOnly(c)) consultation = c;
}

const related = fillRelatedArticles(allArticles, post, 3);

const siteBase = Astro.site ?? new URL('https://wellnessfirstglobal.com');
const articlePageUrl = new URL(publicPath, siteBase).toString();
const articleLd = articleJsonLd({
  headline: title,
  description: metaDescription,
  url: articlePageUrl,
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  authorName: author,
  imageUrls: coverImage ? [coverImage] : undefined,
});
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonicalPath={publicPath}
  ogImagePath={coverImage}
  ogImageAlt={coverImage ? `Cover image: ${title}` : undefined}
  ogType="article"
  articlePublishedTime={publishedAt.toISOString()}
  articleModifiedTime={updatedAt ? updatedAt.toISOString() : undefined}
  articleAuthor={author}
  articleSection={category}
  jsonLd={articleLd}
  {...marketingPageLayout}
>
  <article>
    <MarketingHero
      eyebrow={category}
      subtitle={subtitle}
      title={title}
      description={excerpt}
      imageUrl={coverImage}
      imageAlt={coverImage ? `Cover image: ${title}` : `Article: ${title}`}
      imageObjectFit={coverImageFit === 'contain' ? 'contain' : 'cover'}
    >
      <div slot="actions" class="flex flex-col gap-4">
        <p class="wfg-hero-line text-sm text-white/85 [text-shadow:0_1px_1px_rgba(0,0,0,0.15)]">
          By {author} · {formatDate(publishedAt)}
          {updatedAt && ` · Updated ${formatDate(updatedAt)}`}
        </p>
        {allowFavoriteReflection && <ArticleFavoriteButton slug={catalogSlug} variant="detail" />}
      </div>
    </MarketingHero>
    {
      accessLevel === 'public' && (
        <Section tone="contrast" spacing="comfortable" class="!pt-8 sm:!pt-10 md:!pt-12">
          <Container narrow>
            <p
              class="mb-8 max-w-prose border-b border-ink/10 pb-8 text-balance text-base leading-[1.75] text-charcoal sm:mb-10 sm:pb-10 sm:text-lg"
            >
              Welcome. This is long-form writing—meant to be read in a calm stretch, and to revisit when the questions in your
              life resurface. There is no score here; only language you can use in a real week.
            </p>
            <RichText as="div" variant="article">
              {Content ? (
                <Content
                  components={{
                    Cta: ArticleCta,
                    ArticleCta: ArticleCta,
                  }}
                />
              ) : null}
            </RichText>
          </Container>
        </Section>
      )
    }
    {
      accessLevel === 'member' && (
        <Section tone="contrast" spacing="comfortable" class="!pt-8 sm:!pt-10 md:!pt-12">
          <Container narrow>
            <div data-member-article-root data-catalog-slug={catalogSlug} data-access-level="member">
              <div data-member-soft-gate>
                <AccessGate variant="member_soft_gate" nextPath={publicPath} lead={excerpt} />
              </div>
              <div data-member-body-wrap class="hidden">
                <p
                  data-member-article-status
                  class="mb-4 hidden text-sm text-ink-600"
                  role="status"
                  aria-live="polite"
                />
                <div data-member-article-html class="rich-text max-w-[var(--width-prose)]"></div>
              </div>
            </div>
          </Container>
        </Section>
      )
    }
    {
      (accessLevel === 'paid' || accessLevel === 'webinar_participants') && (
        <Section tone="contrast" spacing="comfortable" class="!pt-8 sm:!pt-10 md:!pt-12">
          <Container narrow>
            <AccessGate
              variant={accessLevel === 'paid' ? 'paid_locked' : 'webinar_locked'}
              nextPath={publicPath}
              lead={excerpt}
            />
          </Container>
        </Section>
      )
    }
    {allowFavoriteReflection && <ArticleReflectionPanel catalogSlug={catalogSlug} />}
    {
      related.length > 0 && (
        <Section tone="default" spacing="comfortable" class="!pt-0" aria-label="Related reading">
          <Container>
            <h2 class="text-eyebrow">Related reading</h2>
            <p class="mt-1 font-display text-2xl text-ink-800 md:text-3xl">More articles</p>
            <ul
              class="mt-8 grid list-none grid-cols-1 gap-6 sm:gap-7 md:grid-cols-2 lg:grid-cols-3 lg:gap-8"
              role="list"
            >
              {related.map((entry) => (
                <li>
                  <ArticleCard entry={entry} showFeaturedBadge={true} />
                </li>
              ))}
            </ul>
          </Container>
        </Section>
      )
    }
    <ArticleRelatedOffers products={productEntries} webinar={webinar} consultation={consultation} />
    <CommunitySpine page="article" compact class="!border-t-0" id="spine-after-article" />
  </article>
  <HomePageFooter slot="footer" />
</BaseLayout>

<script>
  import { initArticleFavorites } from '@/scripts/article-favorites';
  import { initArticleReflectionPanel } from '@/scripts/article-reflection-panel';
  import { initArticleMemberAccess } from '@/scripts/article-member-access';
  initArticleFavorites();
  initArticleReflectionPanel();
  initArticleMemberAccess();
</script>
