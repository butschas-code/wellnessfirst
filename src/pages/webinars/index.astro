---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import MarketingHero from '@/components/layout/MarketingHero.astro';
import HomePageFooter from '@/components/home/HomePageFooter.astro';
import { marketingPageLayout } from '@/lib/marketing-page';
import Section from '@/components/layout/Section.astro';
import Container from '@/components/layout/Container.astro';
import ConversionCallout from '@/components/conversion/ConversionCallout.astro';
import EmptyState from '@/components/conversion/EmptyState.astro';
import WebinarCardDb from '@/components/cards/WebinarCardDb.astro';
import CommunitySpine from '@/components/community/CommunitySpine.astro';
import { fetchWebinarsForBuild } from '@/lib/supabase/webinar-build-fetch';
import { formatWebinarScheduleStart } from '@/lib/webinars/format-schedule';

const webinars = await fetchWebinarsForBuild();

function webinarEndedRow(r: (typeof webinars)[0]): boolean {
  const t = r.ends_at ? new Date(r.ends_at).getTime() : new Date(r.starts_at).getTime();
  return t < Date.now();
}

const nextLive = webinars
  .filter((w) => w.booking_open && !webinarEndedRow(w))
  .sort((a, b) => new Date(a.starts_at).getTime() - new Date(b.starts_at).getTime())[0];

const fallbackSpotlight = webinars
  .filter((w) => webinarEndedRow(w))
  .sort((a, b) => new Date(b.starts_at).getTime() - new Date(a.starts_at).getTime())[0];

const spotlight = nextLive ?? fallbackSpotlight ?? null;

const spotlightMeta = spotlight ? formatWebinarScheduleStart(spotlight) : null;

const spineSpotlight = spotlight
  ? {
      kicker:
        spotlight.booking_open && !webinarEndedRow(spotlight)
          ? 'Next invitation'
          : spotlight.booking_open
            ? 'Gathering'
            : 'Earlier gathering',
      title: spotlight.title,
      meta: spotlightMeta ?? undefined,
      body:
        spotlight.description?.replace(/\s+/g, ' ').trim().slice(0, 260) ??
        'Teaching with patience — space for honest questions.',
      primary: {
        href: `/webinars/${spotlight.slug}`,
        label: spotlight.booking_open && !webinarEndedRow(spotlight) ? 'Open invitation' : 'View session',
      },
      secondary: { href: '/articles', label: 'Read articles first' },
    }
  : {
      kicker: 'Read first',
      title: 'Arrive at the hour with context',
      body: 'Articles carry the same care as the live room. Pick a theme, then scroll the list below.',
      primary: { href: '/articles', label: 'Browse articles' },
      secondary: { href: '/contact', label: 'Write the desk' },
    };

const filters = [
  { id: 'all', label: 'All' },
  { id: 'live', label: 'Open invitations' },
  { id: 'replay', label: 'Archive' },
] as const;
---

<BaseLayout
  title="Webinars"
  description="Live and recorded sessions with room for questions — teaching with patience and adult attention."
  canonicalPath="/webinars"
  {...marketingPageLayout}
>
  <MarketingHero
    compact
    eyebrow="Gatherings"
    title="Invitations to learn together"
    description="A slower tempo for learning. Clear takeaways, honest uncertainty, and no pressure to be “optimised” by the end of the hour."
  >
    <div slot="actions" class="flex max-w-2xl flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <a class="btn-cta-invert" href="#sessions">Browse gatherings</a>
      <a class="btn-cta-invert-ghost" href="/articles">Read articles first</a>
    </div>
  </MarketingHero>

  <CommunitySpine page="webinars" id="spine-webinars" spotlight={spineSpotlight} />
  <Section id="sessions" tone="minimal" spacing="comfortable" class="scroll-mt-28 !pt-0 sm:!pt-2">
    <Container>
      {
        webinars.length > 0 && (
          <>
            <p class="text-label">Filter</p>
            <div class="mt-3 flex flex-wrap gap-2" role="group" aria-label="Filter sessions" data-webinar-filters>
              {filters.map((f) => (
                <button
                  type="button"
                  class="btn-filter-pill"
                  data-webinar-filter={f.id}
                  aria-pressed={f.id === 'all' ? 'true' : 'false'}
                >
                  {f.label}
                </button>
              ))}
            </div>
          </>
        )
      }

      {
        webinars.length === 0 && (
          <EmptyState
            title="Gatherings rest between seasons"
            body="When the next invitation is ready, it will sit here with full context — no countdown theatre. Meanwhile, articles carry the same care in writing."
            actionHref="/articles"
            actionLabel="Read articles"
            secondaryHref="/contact"
            secondaryLabel="Ask to be notified"
          />
        )
      }
      {
        webinars.length > 0 && (
          <ul
            class="mt-8 list-none grid grid-cols-1 gap-6 sm:mt-10 sm:grid-cols-2 sm:gap-7"
            role="list"
            data-webinar-list
          >
            {webinars.map((w) => {
              const ended = webinarEndedRow(w);
              const fmt = w.booking_open && !ended ? 'live' : 'replay';
              return (
                <li class="min-h-0" data-webinar-item data-webinar-format={fmt}>
                  <WebinarCardDb row={w} />
                </li>
              );
            })}
          </ul>
        )
      }
      {
        webinars.length > 0 && (
          <div
            data-webinar-no-match
            class="mt-2 hidden border-0 border-t-2 border-dashed border-ink/25 bg-white py-10"
            role="status"
            aria-live="polite"
          >
            <p class="font-display text-xl text-ink-800">Nothing matches this filter</p>
            <p class="mt-2 text-ink-600">Try “All” — or write if you are looking for something specific.</p>
            <div class="mt-6 flex flex-wrap gap-3">
              <button type="button" class="btn-primary" data-webinar-show-all>
                Show all
              </button>
              <a class="btn-secondary" href="/contact">
                Write the desk
              </a>
            </div>
          </div>
        )
      }
    </Container>
  </Section>
  <div slot="prefooter">
    <ConversionCallout topic="webinars" />
  </div>
  <HomePageFooter slot="footer" />
</BaseLayout>

<script>
  const root = document.querySelector('[data-webinar-filters]');
  const noMatch = document.querySelector('[data-webinar-no-match]') as HTMLElement | null;
  const applyFilter = (raw: string) => {
    document.querySelectorAll('[data-webinar-item]').forEach((li) => {
      const f = (li as HTMLElement).dataset.webinarFormat;
      let show = raw === 'all';
      if (raw === 'live' || raw === 'replay') show = f === raw;
      li.classList.toggle('hidden', !show);
    });
  };
  const updateNoMatch = () => {
    const rows = document.querySelectorAll('[data-webinar-item]');
    let visible = 0;
    rows.forEach((li) => {
      if (!li.classList.contains('hidden')) visible += 1;
    });
    if (noMatch) {
      const hide = visible > 0;
      noMatch.classList.toggle('hidden', hide);
    }
  };
  document.querySelector('[data-webinar-show-all]')?.addEventListener('click', () => {
    if (!root) return;
    const allBtn = root.querySelector('button[data-webinar-filter="all"]') as HTMLButtonElement | null;
    allBtn?.click();
  });
  if (root) {
    root.querySelectorAll('button[data-webinar-filter]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const raw = btn.getAttribute('data-webinar-filter') || 'all';
        root.querySelectorAll('button[data-webinar-filter]').forEach((b) => b.setAttribute('aria-pressed', 'false'));
        btn.setAttribute('aria-pressed', 'true');
        applyFilter(raw);
        updateNoMatch();
      });
    });
    updateNoMatch();
  }
</script>
