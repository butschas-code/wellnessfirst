# Local overrides (optional). Astro/Vite loads `.env`, `.env.local`, `.env.[mode].local`.
# Same variables as `.env.example`; use either file — do not commit real keys.

# ─── Equivalent to Next.js NEXT_PUBLIC_* ───────────────────────────────────────
# Astro exposes only variables prefixed with PUBLIC_ to the browser bundle.

PUBLIC_SUPABASE_URL=https://zcxlsqimyuaxcuersdyv.supabase.co
PUBLIC_SUPABASE_ANON_KEY=

# Paste the anon (public) key from Supabase → Settings → API. Never put service_role here.

# Optional — POST JSON on successful RSVP (see `.env.example`).
# PUBLIC_WEBINAR_BOOKING_NOTIFY_URL=
